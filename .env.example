# Copy to `.env.local` for local development (never commit secrets).

# Database (required for auth persistence + `/api/v1/projects`)
DATABASE_URL=postgresql://postgres:sonara@localhost:5432/sonara_dev

# Auth.js / NextAuth v5
AUTH_SECRET=replace-with-32-plus-char-secret
NEXTAUTH_URL=http://localhost:3000

# OAuth (optional — omit to disable providers)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Supabase Storage (optional — `/api/v1/assets/upload` returns 503 without these)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=sonara-audio

# Client toggles
# When true, `/studio`, `/dj`, and protected `/api/v1/*` require a session (via middleware).
NEXT_PUBLIC_REQUIRE_AUTH=false
# When DATABASE_URL is unset, guest usage stays enabled unless set to "false".
NEXT_PUBLIC_ALLOW_GUEST_WITHOUT_DB=true

# ---- Publishing (Phase 3) ----
# AES-256-GCM key for encrypting third-party access/refresh tokens at rest (32 raw bytes, base64).
PUBLISH_TOKEN_KEY=

# SoundCloud OAuth (Authorization Code + PKCE)
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
# Optional override; defaults to `${NEXTAUTH_URL}/api/v1/publish/soundcloud/callback`
SOUNDCLOUD_REDIRECT_URI=

# YouTube upload OAuth (separate from NextAuth Google sign-in for minimal scopes)
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
# Optional override; defaults to `${NEXTAUTH_URL}/api/v1/publish/youtube/callback`
YOUTUBE_OAUTH_REDIRECT_URI=

# Dev-only: bypass real provider HTTP during automated tests / constrained environments
PUBLISH_MOCK_PROVIDERS=false
# Optional fixed access token string returned when mocks enabled (defaults to "mock-access-token")
PUBLISH_MOCK_ACCESS_TOKEN=

# ---- AI generation (Phase 4) ----
# Client: `mock` (default) keeps procedural generation in-browser. `server` uses `/api/v1/generate` when the server reports `replicate`.
NEXT_PUBLIC_AI_GENERATE_BACKEND=mock
# Server: `mock` (default) disables POST /api/v1/generate (503). `replicate` requires DATABASE_URL + token + version + webhook secret.
AI_PROVIDER=mock
REPLICATE_API_TOKEN=
# Pin a Stable Audio Open version id from https://replicate.com/stability-ai/stable-audio-open-1.0
REPLICATE_STABLE_AUDIO_VERSION=
REPLICATE_WEBHOOK_SIGNING_SECRET=
# Optional; defaults to NEXTAUTH_URL (use ngrok/cloudflared URL for local webhook delivery)
REPLICATE_WEBHOOK_PUBLIC_BASE_URL=
# Per-user daily sum of requested durationSec (UTC day). Default 600.
AI_GENERATE_DAILY_SECONDS_LIMIT=600
